{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Question paper blueprint",
  "type": "object",
  "required": ["meta", "slots"],
  "properties": {
    "meta": {
      "type": "object",
      "required": ["total_marks", "duration_minutes", "level", "mode"],
      "properties": {
        "title": { "type": "string" },
        "total_marks": { "type": "integer", "minimum": 1 },
        "duration_minutes": { "type": "integer", "minimum": 1 },
        "level": { "type": "string" },
        "mode": { "enum": ["graded_paper", "practice_sheet"] },
        "notes": { "type": "string" }
      }
    },
    "slots": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["slot_id", "marks", "type", "bloom", "difficulty", "topic", "source_anchors"],
        "properties": {
          "slot_id": { "type": "string", "pattern": "^q[0-9]+[a-z]?$" },
          "section": { "type": "string" },
          "marks": { "type": "integer", "minimum": 1 },
          "type": {
            "enum": ["mcq", "true_false", "fill_blank", "short_answer", "numerical", "long_answer", "diagram_label"]
          },
          "bloom": {
            "enum": ["remember", "understand", "apply", "analyze", "evaluate", "create"]
          },
          "difficulty": { "enum": ["easy", "medium", "hard"] },
          "topic": { "type": "string" },
          "source_anchors": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "object",
              "required": ["locator"],
              "properties": {
                "locator": { "type": "string" },
                "quote": { "type": "string", "maxLength": 60 }
              }
            }
          },
          "constraints": { "type": "string" }
        }
      }
    }
  }
}
